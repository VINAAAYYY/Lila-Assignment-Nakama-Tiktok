# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_in_production

# ── Nakama server ─────────────────────────────────────────────────────────────
SERVER_KEY=changeme_server_key
LOG_LEVEL=INFO                  # DEBUG | INFO | WARN | ERROR
SESSION_EXPIRY=86400            # seconds (24h default)

# ── Runtime feature flags (forwarded into ctx.env) ───────────────────────────
TICK_RATE=1
TURN_TIMEOUT_SEC=30
DEFAULT_MODE=classic            # classic | timed
LEADERBOARD_TOP_N=10
TIMED_MODE_ENABLED=true
LEADERBOARD_ENABLED=true
MATCH_HISTORY_ENABLED=true
ANALYTICS_ENABLED=false         # set true when an analytics adapter is wired
